{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://defaultcreds.local/schema/product.schema.json",
  "title": "defaultcreds product",
  "type": "object",
  "additionalProperties": false,
  "required": ["product", "slug", "vendor", "category", "credentials"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "product": {
      "type": "string",
      "minLength": 1
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "vendor": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "services": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "ports": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 1,
        "maximum": 65535
      },
      "uniqueItems": true
    },
    "protocols": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "loginPaths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "uniqueItems": true
    },
    "credentials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/credential"
      }
    }
  },
  "$defs": {
    "credential": {
      "type": "object",
      "additionalProperties": false,
      "required": ["username", "password", "status"],
      "properties": {
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "versions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "introduced": {
          "type": "string"
        },
        "removed": {
          "type": "string"
        },
        "status": {
          "enum": ["active", "historical", "reported", "no-default", "unknown"]
        },
        "context": {
          "enum": ["upstream", "vendor-appliance", "docker-image", "distro-package", "ctf-lab", "sample-config", "unknown"]
        },
        "confidence": {
          "enum": ["confirmed", "vendor-docs", "community-reported", "lab-only", "unknown"]
        },
        "sourceType": {
          "enum": ["vendor-doc", "manual", "sample-config", "community-list", "ctf", "unknown"]
        },
        "services": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "ports": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "uniqueItems": true
        },
        "protocols": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "loginPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "lastVerified": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "string"
        },
        "scopeNote": {
          "type": "string"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uri"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
