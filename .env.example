# Operator details rendered on the Impressum / Datenschutz pages.
# Set the real values in Vercel → Project → Settings → Environment Variables,
# and in a local .env.local (git-ignored) for `npm run dev`.
# These are intentionally NOT in the repo so the project can be public.
IMPRESSUM_NAME="Your Name"
IMPRESSUM_STREET="Street and number"
IMPRESSUM_POSTAL_CODE="12345"
IMPRESSUM_CITY="City"
IMPRESSUM_COUNTRY="Deutschland"
IMPRESSUM_EMAIL="contact@example.com"
IMPRESSUM_VAT_ID=""
